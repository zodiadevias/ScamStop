{
    "name": "scam-stop",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "build:extension": "ng build --configuration production",
        "watch": "ng build --watch --configuration development",
        "watch:extension": "ng build --watch --configuration production",
        "test": "ng test",
        "build:prod": "ng build --configuration production",
        "package:extension": "npm run build:prod && powershell -Command \"Compress-Archive -Path dist/ScamStop/browser/* -DestinationPath scamstop-extension.zip -Force\""
    },
    "private": true,
    "packageManager": "npm@11.12.1",
    "dependencies": {
        "@angular/common": "^21.2.0",
        "@angular/compiler": "^21.2.0",
        "@angular/core": "^21.2.0",
        "@angular/forms": "^21.2.0",
        "@angular/platform-browser": "^21.2.0",
        "@angular/router": "^21.2.0",
        "firebase": "^12.12.1",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^21.2.7",
        "@angular/cli": "^21.2.7",
        "@angular/compiler-cli": "^21.2.0",
        "jsdom": "^28.0.0",
        "prettier": "^3.8.1",
        "typescript": "~5.9.2",
        "vitest": "^4.0.8"
    }
}
